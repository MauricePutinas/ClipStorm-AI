# ------------------------------------------------------------------
# ClipStorm AI – Beispiel-Umgebungsvariablen
# Kopiere diese Datei zu ".env" und fülle die Werte aus.
# In der lokalen Demo funktioniert die App OHNE externe Keys.
# ------------------------------------------------------------------

# Datenbank (SQLite lokal)
DATABASE_URL="file:./dev.db"

# Öffentliche App-URL (für Checkout-Redirects / Webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------
# AI Provider (optional – Standard ist der lokale Template-Provider)
# Mögliche Werte: template | openai | claude | deepseek
# ------------------------------------------------------------------
AI_PROVIDER="template"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""

# ------------------------------------------------------------------
# Lemon Squeezy (Monetarisierung) – KEINE echten Keys committen!
# ------------------------------------------------------------------
LEMON_SQUEEZY_API_KEY=""
LEMON_SQUEEZY_WEBHOOK_SECRET=""
LEMON_SQUEEZY_STORE_ID=""

# Öffentliche Checkout-URLs (werden im Frontend für die Pricing-Buttons genutzt)
NEXT_PUBLIC_LEMON_SQUEEZY_CREATOR_CHECKOUT_URL=""
NEXT_PUBLIC_LEMON_SQUEEZY_PRO_CHECKOUT_URL=""
NEXT_PUBLIC_LEMON_SQUEEZY_AGENCY_CHECKOUT_URL=""

# Admin-Schutz (einfacher Demo-Token; in Produktion durch echtes Auth ersetzen)
ADMIN_TOKEN="clipstorm-admin"
